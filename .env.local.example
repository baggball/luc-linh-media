# Sao chép file này thành .env.local rồi điền giá trị thật từ Supabase
# Project Settings → Data API (Project URL) và Project Settings → API Keys (Publishable key)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SITE_URL=https://luclinhvideoai.com

# Chỉ dùng server-side (không có tiền tố NEXT_PUBLIC_) — không bao giờ commit giá trị thật.
# Supabase Project Settings → API Keys → Secret keys. Dùng để webhook SePay bỏ qua RLS khi xác nhận thanh toán.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# SePay: my.sepay.vn → Webhooks → Add webhook (chọn xác thực API Key), và tài khoản ngân hàng đã kết nối SePay.
SEPAY_WEBHOOK_API_KEY=xxxxxxxxxxxxxxxxxxxx
SEPAY_BANK_ACCOUNT=0123456789
SEPAY_BANK_NAME=Vietcombank
SEPAY_BANK_ACCOUNT_NAME=NGUYEN VAN A
